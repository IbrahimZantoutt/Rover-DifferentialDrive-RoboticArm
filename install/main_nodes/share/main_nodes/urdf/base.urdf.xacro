<?xml version="1.0"?>

<robot name="r2d2" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="robot_base" >
        <visual>
            <origin xyz="0 0 0.06" rpy="0 0 0"/>
            <geometry>
                <box size="0.55 0.35 0.13" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.06" rpy="0 0 0"/>
             <geometry>
                <box size="0.28 0.28 0.35" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.175" rpy="0 0 0"/>
            <mass value="3.0"/>
            <inertia ixx="0.0502" ixy="0" ixz="0"
                     iyy="0.0502" iyz="0"
                     izz="0.0392"/>
        </inertial>
    </link>

    <!-- left wheels -->
    <link name="left_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.035"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.07" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.000211" ixy="0" ixz="0"
                     iyy="0.000211" iyz="0"
                     izz="0.00036"/>
        </inertial>
    </link>

    <joint name="left_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel1"/>
        <origin xyz="-0.15 0.18 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.035"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.07" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.000211" ixy="0" ixz="0"
                     iyy="0.000211" iyz="0"
                     izz="0.00036"/>
        </inertial>
    </link>

    <joint name="left_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel2"/>
        <origin xyz="0.15 0.18 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <!-- right wheels -->


    <link name="right_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.035"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.07" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.000211" ixy="0" ixz="0"
                     iyy="0.000211" iyz="0"
                     izz="0.00036"/>
        </inertial>
    </link>

    <joint name="right_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel1"/>
        <origin xyz="-0.15 -0.18 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.035"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.07" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.000211" ixy="0" ixz="0"
                     iyy="0.000211" iyz="0"
                     izz="0.00036"/>
        </inertial>
    </link>

    <joint name="right_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel2"/>
        <origin xyz="0.15 -0.18 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- wheel friction (helps the wheels grip the ground plane) -->
    <gazebo reference="left_wheel1"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
    <gazebo reference="left_wheel2"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
    <gazebo reference="right_wheel1"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
    <gazebo reference="right_wheel2"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>

    <!-- Differential drive controller (publishes /odom + odom->robot_base TF,
         subscribes to /cmd_vel). Two wheel pairs driven together. -->
    <gazebo>
        <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
            <ros>
                <namespace>/</namespace>
            </ros>

            <num_wheel_pairs>2</num_wheel_pairs>

            <!-- pair 1 -->
            <left_joint>left_wheel1_joint</left_joint>
            <right_joint>right_wheel1_joint</right_joint>
            <!-- pair 2 -->
            <left_joint>left_wheel2_joint</left_joint>
            <right_joint>right_wheel2_joint</right_joint>

            <wheel_separation>0.308</wheel_separation>
            <wheel_separation>0.308</wheel_separation>
            <wheel_diameter>0.098</wheel_diameter>
            <wheel_diameter>0.098</wheel_diameter>

            <max_wheel_torque>20.0</max_wheel_torque>
            <max_wheel_acceleration>1.0</max_wheel_acceleration>

            <command_topic>cmd_vel</command_topic>
            <odometry_topic>odom</odometry_topic>
            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>robot_base</robot_base_frame>

            <publish_odom>true</publish_odom>
            <publish_odom_tf>true</publish_odom_tf>
            <publish_wheel_tf>true</publish_wheel_tf>
        </plugin>
    </gazebo>

</robot>
