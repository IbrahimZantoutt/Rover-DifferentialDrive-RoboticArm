<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="mobiarm_ros2_control" params="name initial_positions_file use_gazebo:=false">
        <xacro:property name="initial_positions" value="${load_yaml(initial_positions_file)['initial_positions']}"/>

        <ros2_control name="${name}" type="system">
            <hardware>
                <xacro:if value="${use_gazebo}">
                    <!-- Gazebo Classic: the controller_manager runs inside Gazebo -->
                    <plugin>gazebo_ros2_control/GazeboSystem</plugin>
                </xacro:if>
                <xacro:unless value="${use_gazebo}">
                    <!-- Mock hardware for the RViz-only demo (no physics) -->
                    <plugin>mock_components/GenericSystem</plugin>
                </xacro:unless>
            </hardware>
            <joint name="j1_waist">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['j1_waist']}</param>
                </state_interface>
            </joint>
            <joint name="j2_shoulder">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['j2_shoulder']}</param>
                </state_interface>
            </joint>
            <joint name="j3_elbow">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['j3_elbow']}</param>
                </state_interface>
            </joint>
            <joint name="j4_wrist">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['j4_wrist']}</param>
                </state_interface>
            </joint>
            <joint name="j5_wrist">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['j5_wrist']}</param>
                </state_interface>
            </joint>
            <joint name="j6_wrist">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['j6_wrist']}</param>
                </state_interface>
            </joint>
            <joint name="gripperfinger_left_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['gripperfinger_left_joint']}</param>
                </state_interface>
            </joint>
            <joint name="gripperfinger_right_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['gripperfinger_right_joint']}</param>
                </state_interface>
            </joint>

        </ros2_control>
    </xacro:macro>
</robot>
