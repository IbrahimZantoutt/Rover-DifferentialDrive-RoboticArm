<?xml version="1.0"?>

<robot name="r2d2" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="robot_base" >
        <visual>
            <origin xyz="0 0 0.06" rpy="0 0 0"/>
            <geometry>
                <box size="0.85 0.55 0.13" />
            </geometry>
        </visual>
        <!-- Collision must match the body so the robot rests on its WHEELS, not
             on an oversized box. The old 0.28x0.28x0.35 box reached down to
             z=-0.115 (below the wheels at -0.08), lifting the wheels off the
             ground -> no traction -> robot couldn't drive. -->
        <collision>
            <origin xyz="0 0 0.06" rpy="0 0 0"/>
             <geometry>
                <box size="0.85 0.55 0.13" />
            </geometry>
        </collision>
        <!-- Inertia recomputed for a 13 kg, 0.85x0.55x0.13 box (I = m(a^2+b^2)/12);
             COM lowered to z=0.04 (near the wheel axles) to resist tipping. -->
        <inertial>
            <origin xyz="0 0 0.04" rpy="0 0 0"/>
            <mass value="13.0"/>
            <inertia ixx="0.3460" ixy="0" ixz="0"
                     iyy="0.8010" iyz="0"
                     izz="1.1104"/>
        </inertial>
    </link>

    <!-- left wheels -->
    <link name="left_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.0005425" ixy="0" ixz="0"
                     iyy="0.0005425" iyz="0"
                     izz="0.00096"/>
        </inertial>
    </link>

    <joint name="left_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel1"/>
        <origin xyz="-0.3 0.27 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.0005425" ixy="0" ixz="0"
                     iyy="0.0005425" iyz="0"
                     izz="0.00096"/>
        </inertial>
    </link>

    <joint name="left_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel2"/>
        <origin xyz="0.3 0.27 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <!-- right wheels -->


    <link name="right_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.0005425" ixy="0" ixz="0"
                     iyy="0.0005425" iyz="0"
                     izz="0.00096"/>
        </inertial>
    </link>

    <joint name="right_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel1"/>
        <origin xyz="-0.3 -0.27 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.0005425" ixy="0" ixz="0"
                     iyy="0.0005425" iyz="0"
                     izz="0.00096"/>
        </inertial>
    </link>

    <joint name="right_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel2"/>
        <origin xyz="0.3 -0.27 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- Skid-steer wheel friction. fdir1 = "1 0 0" pins friction axis 1 to the
         wheel's ROLLING direction (base +x); each wheel link is only rotated about
         x, so its local x = base x. Then:
           mu1 (rolling)  = 1.0  -> forward traction, unchanged
           mu2 (lateral)  = 0.0  -> wheels can scrub SIDEWAYS freely, so the base
                                    can actually yaw. With mu2=1.0 the wheels were
                                    laterally pinned and the robot could not turn
                                    (measured ~11% of commanded rotation). -->
    <gazebo reference="left_wheel1"><mu1>1.0</mu1><mu2>0.7</mu2><fdir1>1 0 0</fdir1></gazebo>
    <gazebo reference="left_wheel2"><mu1>1.0</mu1><mu2>0.7</mu2><fdir1>1 0 0</fdir1></gazebo>
    <gazebo reference="right_wheel1"><mu1>1.0</mu1><mu2>0.7</mu2><fdir1>1 0 0</fdir1></gazebo>
    <gazebo reference="right_wheel2"><mu1>1.0</mu1><mu2>0.7</mu2><fdir1>1 0 0</fdir1></gazebo>

    <!-- Differential drive controller (publishes /odom + odom->robot_base TF,
         subscribes to /cmd_vel). Two wheel pairs driven together. -->
    <gazebo>
        <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
            <ros>
                <namespace>/</namespace>
            </ros>

            <num_wheel_pairs>2</num_wheel_pairs>

            <!-- pair 1 -->
            <left_joint>left_wheel1_joint</left_joint>
            <right_joint>right_wheel1_joint</right_joint>
            <!-- pair 2 -->
            <left_joint>left_wheel2_joint</left_joint>
            <right_joint>right_wheel2_joint</right_joint>

            <wheel_separation>0.54</wheel_separation>
            <wheel_separation>0.54</wheel_separation>
            <wheel_diameter>0.16</wheel_diameter>
            <wheel_diameter>0.16</wheel_diameter>

            <max_wheel_torque>20.0</max_wheel_torque>
            <max_wheel_acceleration>1.0</max_wheel_acceleration>

            <command_topic>cmd_vel</command_topic>
            <odometry_topic>odom</odometry_topic>
            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>robot_base</robot_base_frame>

            <publish_odom>true</publish_odom>
            <!-- DIAGNOSTIC A/B: set back to true so the plugin publishes odom->robot_base
                 itself (pure wheel odometry, pre-EKF behaviour). MUST disable the ekf_node
                 in nav2_slam.launch.py at the same time, or two nodes publish the same TF
                 and fight. Set back to false + re-enable EKF to restore the fused setup. -->
            <publish_odom_tf>true</publish_odom_tf>
            <publish_wheel_tf>true</publish_wheel_tf>
        </plugin>
    </gazebo>

</robot>
