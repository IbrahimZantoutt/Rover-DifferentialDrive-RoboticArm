<?xml version="1.0"?>

<robot name="r2d2" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="robot_base" >
        <visual>
            <origin xyz="0 0 0.06" rpy="0 0 0"/>
            <geometry>
                <box size="0.85 0.55 0.13" />
            </geometry>
        </visual>
        <!-- Collision matches the body so the robot rests on its wheels; an
             oversized box lifted the wheels off the ground (no traction). -->
        <collision>
            <origin xyz="0 0 0.06" rpy="0 0 0"/>
             <geometry>
                <box size="0.85 0.55 0.13" />
            </geometry>
        </collision>
        <!-- Inertia for a 13 kg 0.85x0.55x0.13 box; COM lowered to z=0.04 to resist tipping. -->
        <inertial>
            <origin xyz="0 0 0.04" rpy="0 0 0"/>
            <mass value="13.0"/>
            <inertia ixx="0.3460" ixy="0" ixz="0"
                     iyy="0.8010" iyz="0"
                     izz="1.1104"/>
        </inertial>
    </link>

    <link name="left_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.0005425" ixy="0" ixz="0"
                     iyy="0.0005425" iyz="0"
                     izz="0.00096"/>
        </inertial>
    </link>

    <joint name="left_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel1"/>
        <origin xyz="-0.3 0.27 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.0005425" ixy="0" ixz="0"
                     iyy="0.0005425" iyz="0"
                     izz="0.00096"/>
        </inertial>
    </link>

    <joint name="left_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel2"/>
        <origin xyz="0.3 0.27 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <link name="right_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.0005425" ixy="0" ixz="0"
                     iyy="0.0005425" iyz="0"
                     izz="0.00096"/>
        </inertial>
    </link>

    <joint name="right_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel1"/>
        <origin xyz="-0.3 -0.27 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.0005425" ixy="0" ixz="0"
                     iyy="0.0005425" iyz="0"
                     izz="0.00096"/>
        </inertial>
    </link>

    <joint name="right_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel2"/>
        <origin xyz="0.3 -0.27 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- Skid-steer friction: fdir1 pins axis 1 to the rolling dir. mu1=1 (forward
         traction); mu2 low so wheels scrub sideways and the base can yaw (mu2=1
         pinned them laterally -> ~11% of commanded rotation). -->
    <gazebo reference="left_wheel1"><mu1>1.0</mu1><mu2>0.7</mu2><fdir1>1 0 0</fdir1></gazebo>
    <gazebo reference="left_wheel2"><mu1>1.0</mu1><mu2>0.7</mu2><fdir1>1 0 0</fdir1></gazebo>
    <gazebo reference="right_wheel1"><mu1>1.0</mu1><mu2>0.7</mu2><fdir1>1 0 0</fdir1></gazebo>
    <gazebo reference="right_wheel2"><mu1>1.0</mu1><mu2>0.7</mu2><fdir1>1 0 0</fdir1></gazebo>

    <!-- Differential drive: publishes /odom + odom->robot_base TF, subscribes /cmd_vel. -->
    <gazebo>
        <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
            <ros>
                <namespace>/</namespace>
            </ros>

            <num_wheel_pairs>2</num_wheel_pairs>

            <!-- pair 1 -->
            <left_joint>left_wheel1_joint</left_joint>
            <right_joint>right_wheel1_joint</right_joint>
            <!-- pair 2 -->
            <left_joint>left_wheel2_joint</left_joint>
            <right_joint>right_wheel2_joint</right_joint>

            <wheel_separation>0.54</wheel_separation>
            <wheel_separation>0.54</wheel_separation>
            <wheel_diameter>0.16</wheel_diameter>
            <wheel_diameter>0.16</wheel_diameter>

            <max_wheel_torque>20.0</max_wheel_torque>
            <max_wheel_acceleration>1.0</max_wheel_acceleration>

            <command_topic>cmd_vel</command_topic>
            <odometry_topic>odom</odometry_topic>
            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>robot_base</robot_base_frame>

            <publish_odom>true</publish_odom>
            <!-- odom->robot_base from wheel odometry only; an EKF/IMU fusion here
                 caused a yaw-dependent scan shift during turns. SLAM's map->odom
                 absorbs the drift. -->
            <publish_odom_tf>true</publish_odom_tf>
            <publish_wheel_tf>true</publish_wheel_tf>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin name="wheel_joint_states" filename="libgazebo_ros_joint_state_publisher.so">
            <ros><namespace>/</namespace></ros>
            <update_rate>30</update_rate>
            <joint_name>left_wheel1_joint</joint_name>
            <joint_name>left_wheel2_joint</joint_name>
            <joint_name>right_wheel1_joint</joint_name>
            <joint_name>right_wheel2_joint</joint_name>
        </plugin>
    </gazebo>


</robot>
