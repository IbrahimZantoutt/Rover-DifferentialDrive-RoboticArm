<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mobiarm">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import mobiarm urdf file -->
    <xacro:include filename="$(find main_nodes)/urdf/robot.urdf.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="mobiarm.ros2_control.xacro" />


    <xacro:mobiarm_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
